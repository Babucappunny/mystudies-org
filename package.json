{
  "name": "vidya-cloudflare",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "wrangler dev",
    "db:local:schema": "wrangler d1 execute vidya-db --local --file=./schema.sql",
    "db:local:seed": "wrangler d1 execute vidya-db --local --file=./seed.sql",
    "db:remote:schema": "wrangler d1 execute vidya-db --remote --file=./schema.sql",
    "db:remote:seed": "wrangler d1 execute vidya-db --remote --file=./seed.sql",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
